# Core runtime
TZ=America/New_York
PUID=1000
PGID=1000

# Pelican image
PELICAN_IMAGE=ghcr.io/pelican-dev/panel:latest

# Pelican app settings
PELICAN_HTTP_PORT=80
PELICAN_HTTPS_PORT=443
PELICAN_APP_URL=http://localhost
PELICAN_ADMIN_EMAIL=admin@example.com

# App config paths
PELICAN_DATA_PATH=/var/lib/komodo/stacks/pelican/appdata/pelican/data
PELICAN_LOGS_PATH=/var/lib/komodo/stacks/pelican/appdata/pelican/logs
